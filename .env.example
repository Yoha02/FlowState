# Google AI — Gemini 3 Flash (sentiment analysis + task context from screenshot)
GEMINI_API_KEY=

# Anthropic — Claude Computer Use (takes over browser/GCP Cloud Shell)
ANTHROPIC_API_KEY=

# Augment Code — Context Engine MCP (reads codebase when stress detected)
AUGMENT_API_KEY=

# Unkey — API key management + rate limiting all Gemini calls
UNKEY_ROOT_KEY=
UNKEY_API_ID=

# DigitalOcean — App Platform deploy + Gradient inference endpoint
DO_API_KEY=
DO_GRADIENT_BASE_URL=https://inference.do-ai.run/v1

# App config
STRESS_THRESHOLD=3
TICK_WEBCAM_SECONDS=5
TICK_SCREEN_SECONDS=15
HANDOFF_TIMEOUT_SECONDS=30

# Demo target (the broken Cloud Run service used in the 3-min demo)
DEMO_GCP_PROJECT=
DEMO_CLOUD_RUN_SERVICE=
